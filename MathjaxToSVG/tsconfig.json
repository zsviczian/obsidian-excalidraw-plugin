{
  "compilerOptions": {
    "baseUrl": ".",
    "sourceMap": true,
    "module": "es2022",
    "target": "es2022",
    "allowJs": false,
    "noImplicitAny": true,
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "importHelpers": true,
    "resolveJsonModule": true,
    "lib": [
      "dom",
      "scripthost",
      "es2022",
      "DOM.Iterable"
    ],
    "jsx": "react"
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "src/shared/Dialogs/OpenDrawing.ts",
    "src/types/types.d.ts"
  ]
}